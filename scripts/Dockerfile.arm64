# ARM64 Dockerfile for BinBench Evaluation
# Designed for Podman on macOS Apple Silicon (ARM64 VM).
# Runs Frida on native ARM64 to avoid ptrace issues caused by QEMU emulation.

FROM --platform=linux/arm64 swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Use Aliyun mirrors to speed up package installation.
RUN sed -i 's/ports.ubuntu.com/mirrors.aliyun.com/g' /etc/apt/sources.list && \
    sed -i 's/archive.ubuntu.com/mirrors.aliyun.com/g' /etc/apt/sources.list && \
    sed -i 's/security.ubuntu.com/mirrors.aliyun.com/g' /etc/apt/sources.list

# Install compilers.
# On native ARM64:
# - gcc/g++ are native ARM64 compilers
# - cross toolchains are still installed for other architectures when needed
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    build-essential \
    gcc g++ \
    gcc-aarch64-linux-gnu g++-aarch64-linux-gnu \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies.
# frida-tools: semantic instrumentation
# requests: HTTP helpers
# openai: LLM client
RUN pip3 install frida-tools requests openai

WORKDIR /work
